---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Projects — Henry Grantham-Smith"
  description="Software engineering, embedded systems, backend, and performance projects by Henry Grantham-Smith."
>
  <h1>Projects</h1>
  <p class="muted">
    Selected work across embedded systems, application development, performance investigation,
    and reliability-focused software practice.
  </p>

  <div class="list">
    {projects.map((p) => (
      <article class="card">
        <h2 style="margin: 0 0 6px; font-size: 1.1rem">
          <a href={`/projects/${p.slug}/`}>{p.data.title}</a>
        </h2>
        <p class="muted" style="margin: 0 0 10px">{p.data.description}</p>
        <p class="meta" style="margin: 0">
          <span class="muted">{p.data.date.toISOString().slice(0, 10)}</span>
          {p.data.tags.slice(0, 5).map((t) => (
            <span class="tag">#{t}</span>
          ))}
        </p>
      </article>
    ))}
  </div>
</BaseLayout>
