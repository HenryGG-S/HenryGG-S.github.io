---
const path = Astro.url.pathname;

const links = [
  { href: "/", label: "Home", external: false },
  { href: "/projects/", label: "Projects", external: false },
  { href: "mailto:henryg-s@outlook.com", label: "Email", external: true },
  { href: "https://github.com/HenryGG-S", label: "GitHub", external: true },
  { href: "https://www.linkedin.com/in/henry-grantham-smith/", label: "LinkedIn", external: true },
];

const isActive = (href) => {
  if (!href.startsWith("/")) return false;
  if (href === "/") return path === "/";
  return path.startsWith(href);
};
---

<header class="header">
  <a class="skip" href="#content">Skip to content</a>

  <div class="brand">
    <a href="/" class="brandLink">Henry Grantham-Smith</a>
  </div>

  <nav class="nav" aria-label="Primary">
    {links.map((l) =>
      l.external ? (
        <a href={l.href} target={l.href.startsWith("mailto:") ? undefined : "_blank"} rel={l.href.startsWith("mailto:") ? undefined : "me noopener noreferrer"}>
          {l.label}
        </a>
      ) : (
        <a href={l.href} class={isActive(l.href) ? "active" : undefined}>
          {l.label}
        </a>
      )
    )}
  </nav>
</header>
